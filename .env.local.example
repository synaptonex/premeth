# Copy this file to .env.local and fill in your Supabase project values.
# Get them from https://app.supabase.com → your project → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Only needed for the one-time data upload script (scripts/upload-data.mjs).
# Never expose the service role key in client code or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public site URL (used for password reset redirects). In Vercel, set this to
# your deployed URL (e.g. https://premeth.com). For local dev, http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
