# Copy this file to .env.local and fill in your Supabase project values.
# Get them from https://app.supabase.com → your project → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Required. The service-role key is used server-side by the payment routes
# (activating Enid+ on approval, and code redemption) to write subscription
# rows that Row Level Security blocks for normal users. It is also used by the
# one-time data upload script. It must be set in Vercel, or payment approval
# and code redemption will fail. Never expose it in client code or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public site URL (used for password reset redirects). In Vercel, set this to
# your deployed URL (e.g. https://premeth.com). For local dev, http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
